# Copy this file to .env and fill in real values.
# .env is listed in .gitignore and must NEVER be committed.

# --- PostgreSQL / Supabase ---
# Backend currently reads DATABASE_URL (required)
DATABASE_URL=postgresql://postgres:your_db_password_here@your-supabase-host.supabase.co:5432/postgres?sslmode=require

# Legacy fields (optional, not used by backend/database.py right now)
DB_HOST=your-supabase-host.supabase.co
DB_NAME=cleangoal_db
DB_USER=postgres
DB_PASSWORD=your_db_password_here
DB_PORT=5432

# Supabase REST / Auth
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
SUPABASE_DB_SCHEMA=cleangoal

# --- Google Gemini ---
GEMINI_API_KEY=your_gemini_api_key_here

# --- Flutter (Google Maps) ---
# Also update flutter_application_1/lib/config/secrets.dart
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# --- API / CORS ---
# Comma-separated list of origins allowed to call the API from a browser.
# Mobile (Flutter Android/iOS) does NOT need this — mobile clients don't send Origin.
# Leave empty to disable browser-based access entirely.
# Example: ALLOWED_ORIGINS=https://app.calories-guard.example,https://admin.calories-guard.example
ALLOWED_ORIGINS=
