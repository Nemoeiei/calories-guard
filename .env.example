# Copy this file to .env and fill in real values.
# .env is listed in .gitignore and must NEVER be committed.

# --- PostgreSQL / Supabase ---
DB_HOST=your-supabase-host.supabase.co
DB_NAME=cleangoal_db
DB_USER=postgres
DB_PASSWORD=your_db_password_here
DB_PORT=5432

# Supabase REST / Auth
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_PASSWORD=your_supabase_password_here
SUPABASE_JWT_SECRET=your_supabase_jwt_secret_here

# Supabase DB connection (for DB_MODE=supabase)
SUPABASE_HOST=db.your-project.supabase.co
SUPABASE_NAME=postgres
SUPABASE_USER=postgres
SUPABASE_PORT=5432

# Database mode: "local" or "supabase"
DB_MODE=local

# --- Google Gemini ---
GEMINI_API_KEY=your_gemini_api_key_here

# --- Email / SMTP ---
SMTP_EMAIL=your_email@gmail.com
SMTP_PASSWORD=your_gmail_app_password_here

# --- Flutter (Google Maps) ---
# Also update flutter_application_1/lib/config/secrets.dart
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# --- API / CORS ---
# Comma-separated list of origins allowed to call the API from a browser.
# Mobile (Flutter Android/iOS) does NOT need this — mobile clients don't send Origin.
# Leave empty to disable browser-based access entirely.
# Example: ALLOWED_ORIGINS=https://app.calories-guard.example,https://admin.calories-guard.example
ALLOWED_ORIGINS=
