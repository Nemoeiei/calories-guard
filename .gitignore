# Environment / secrets
.env
*.env.local

# Flutter secrets (contains real API keys — never commit)
flutter_application_1/lib/config/secrets.dart

# Android release signing
flutter_application_1/android/key.properties
flutter_application_1/android/*.jks
flutter_application_1/android/app/*.jks

# Python virtual environments — must NEVER be committed
backend/venv/
backend/.venv/
venv/
.venv/

# Python bytecode
__pycache__/
**/__pycache__/
*.pyc
*.pyo
*.pyd

# Python tooling
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/

# Backend debug / scratch dumps
backend/current_db.txt
backend/db_output.txt
backend/db_output_utf8.txt
backend/output_mermaid.txt

# IDE
.idea/
.vscode/

# Claude local settings (may contain personal paths / credentials)
.claude/settings.local.json
.claude/worktrees/

# Android Gradle build cache
flutter_application_1/android/.gradle/
flutter_application_1/android/app/build/

# Flutter generated / lock files (optional — remove if your team checks these in)
flutter_application_1/.flutter-plugins-dependencies
flutter_application_1/.flutter-plugins
flutter_application_1/ios/Flutter/ephemeral/
flutter_application_1/macos/Flutter/ephemeral/
flutter_application_1/linux/flutter/ephemeral/
flutter_application_1/windows/flutter/ephemeral/

# Node.js dependencies (admin-web)
admin-web/node_modules/
**/node_modules/
