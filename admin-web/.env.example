# Copy to .env.local for local dev, or set these in your host's dashboard
# (Cloudflare Pages → Settings → Environment variables) for deploys.

# Backend base URL (no trailing slash)
#   Local dev      : http://localhost:8000
#   Railway staging: https://<your-service>.up.railway.app
#   Production     : https://api.calories-guard.xxx
VITE_API_BASE_URL=http://localhost:8000

# Optional — only needed if the admin panel ever talks to Supabase directly.
# Right now the admin logs in via POST /login and uses the backend-issued JWT,
# so these can be left blank unless you add Supabase-direct features.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
